#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/mouse.h>
#include <dt-bindings/zmk/pointing.h>

#define GRID(n) LC(LA(LG(n)))
#define GRID_FOCUS(n) LC(LA(LG(LS(n))))

/ {
    macros {
        grid5: grid5 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&macro_press &kp LCTRL &kp LALT &kp LGUI>
                     , <&macro_tap &kp N5>
                     , <&macro_release &kp LGUI &kp LALT &kp LCTRL>;
        };

        grid8: grid8 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&macro_press &kp LCTRL &kp LALT &kp LGUI>
                     , <&macro_tap &kp N8>
                     , <&macro_release &kp LGUI &kp LALT &kp LCTRL>;
        };

        /* Hold: send examine-enter signal + activate layer 4
           Release: deactivate layer 4 + send examine-exit signal */
        examine_macro: examine_macro {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&macro_tap &kp GRID_FOCUS(F1)>
                     , <&macro_press &mo 4>
                     , <&macro_pause_for_release>
                     , <&macro_release &mo 4>
                     , <&macro_tap &kp GRID_FOCUS(F2)>;
        };
    };

    behaviors {
        /* Encoder mouse-scroll: works as native HID scroll on iPhone & Mac.
           tap-ms must be long enough for the input-two-axis polling loop
           to emit at least one wheel tick — ~50ms is reliable. */
        enc_scroll: enc_scroll {
            compatible = "zmk,behavior-sensor-rotate";
            #sensor-binding-cells = <0>;
            bindings = <&msc SCRL_DOWN>, <&msc SCRL_UP>;
            tap-ms = <60>;
        };

        /* Hold = momentary layer 1, Tap = grid(5) aka Ctrl+Alt+Cmd+5 */
        ht_l1_g5: ht_l1_g5 {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <200>;
            bindings = <&mo>, <&grid5>;
        };

        /* Hold = momentary focus layer 3, Tap = grid(4) */
        ht_l3_g4: ht_l3_g4 {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <200>;
            bindings = <&mo>, <&kp>;
        };

        /* Hold = examine macro (layer 4 + signals), Tap = grid(8) */
        ht_exam_g8: ht_exam_g8 {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <200>;
            bindings = <&examine_macro>, <&grid8>;
        };

        /* Single/double tap = grid(4), triple tap = toggle layer 2 */
        td_g4_l2: td_g4_l2 {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <300>;
            bindings = <&kp GRID(N4)>, <&kp GRID(N4)>, <&tog 2>;
        };

        /* Single/double tap = right click, triple tap = toggle layer 2 off */
        td_rmb_l0: td_rmb_l0 {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <300>;
            bindings = <&mkp RCLK>, <&mkp RCLK>, <&tog 2>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            // -----------------------------------------------
            // | BT1  | BT2  |       |      |      |
            // | G(1) | G(2) | G(3)  | HF4  |      |
            // | HG5  | G(6) | G(7)  | HE8  |      |
            // -----------------------------------------------
            // Left encoder: HID scroll (iPhone & Mac)    Right encoder: Hammerspoon scroll (Mac only)
            // Hold HF4 = focus layer, Tap = grid(4)
            // Hold HE8 = examine layer, Tap = grid(8)
            // BT_CLR moved to macro_layer (hold bottom-left)
            bindings = <
                &bt BT_SEL 0   &bt BT_SEL 1    &none            &none        &none
                &kp GRID(N1)   &kp GRID(N2)    &kp GRID(N3)     &ht_l3_g4 3 GRID(N4) &none
                &ht_l1_g5 1 0  &kp GRID(N6)    &kp GRID(N7)     &ht_exam_g8 0 0 &none
            >;
            sensor-bindings = <&enc_scroll &inc_dec_kp LC(LA(LG(UP))) LC(LA(LG(DOWN)))>;
        };

        macro_layer {
            // -----------------------------------------------
            // |      |      | BTCLR |      |      |
            // | G(0) | G(9) |  UP   | ESC  |      |
            // | ---- | RGUI | DOWN  | RET  |      |
            // -----------------------------------------------
            bindings = <
                &trans          &trans          &bt BT_CLR       &trans       &trans
                &kp GRID(N0)   &kp GRID(N9)   &kp UP           &kp ESC      &none
                &trans          &kp RGUI        &kp DOWN         &kp RET      &none
            >;
            sensor-bindings = <&enc_scroll &inc_dec_kp LC(LA(LG(UP))) LC(LA(LG(DOWN)))>;
        };

        mouse_layer {
            // -----------------------------------------------
            // |      |      |       |      |      |
            // | PGUP | LMB  | MS_UP | TDRMB|      |
            // | PGDN | MS_L | MS_DN | MS_R |      |
            // -----------------------------------------------
            bindings = <
                &trans         &trans          &trans            &trans       &trans
                &kp PG_UP      &mkp LCLK      &mmv MOVE_UP     &td_rmb_l0   &none
                &kp PG_DN      &mmv MOVE_LEFT  &mmv MOVE_DOWN   &mmv MOVE_RIGHT &none
            >;
            sensor-bindings = <&enc_scroll &inc_dec_kp LC(LA(LG(UP))) LC(LA(LG(DOWN)))>;
        };

        focus_layer {
            // -----------------------------------------------
            // |      |      |       |      |      |
            // | F(1) | F(2) | F(3)  | ---- |      |
            // | F(5) | F(6) | F(7)  | F(8) |      |
            // -----------------------------------------------
            // Focus window at grid position (Ctrl+Alt+Cmd+Shift+N)
            bindings = <
                &none                  &none                  &none                  &none  &none
                &kp GRID_FOCUS(N1)     &kp GRID_FOCUS(N2)     &kp GRID_FOCUS(N3)     &trans &none
                &kp GRID_FOCUS(N5)     &kp GRID_FOCUS(N6)     &kp GRID_FOCUS(N7)     &kp GRID_FOCUS(N8) &none
            >;
            sensor-bindings = <&enc_scroll &inc_dec_kp LC(LA(LG(UP))) LC(LA(LG(DOWN)))>;
        };

        examine_layer {
            // -----------------------------------------------
            // |      |      |       |      |      |
            // |  --  |  --  |  --   | ---- |      |
            // |  --  |  --  |  --   | ---- |      |
            // -----------------------------------------------
            // Grid keys pass through to layer 0 (Hammerspoon checks examine mode)
            // Left encoder: zoom (Ctrl+Alt+Cmd+Shift+minus/equal)
            // Right encoder: scroll (same as default)
            bindings = <
                &trans         &trans          &trans           &trans       &trans
                &trans         &trans          &trans           &trans       &none
                &trans         &trans          &trans           &trans       &none
            >;
            sensor-bindings = <&inc_dec_kp GRID_FOCUS(MINUS) GRID_FOCUS(EQUAL) &inc_dec_kp LC(LA(LG(UP))) LC(LA(LG(DOWN)))>;
        };
    };
};

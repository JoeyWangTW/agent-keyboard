#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix-transform = &default_transform;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <5>;
        rows = <3>;
        map = <
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4)
            RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4)
        >;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        diode-direction = "col2row";
        wakeup-source;

        row-gpios
            = <&pro_micro 19 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  /* Y1 */
            , <&pro_micro 18 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  /* Y2 */
            , <&pro_micro 15 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  /* Y3 */
            ;

        col-gpios
            = <&pro_micro 2 GPIO_ACTIVE_HIGH>  /* X1 */
            , <&pro_micro 3 GPIO_ACTIVE_HIGH>  /* X2 */
            , <&pro_micro 4 GPIO_ACTIVE_HIGH>  /* X3 */
            , <&pro_micro 5 GPIO_ACTIVE_HIGH>  /* X4 */
            , <&pro_micro 6 GPIO_ACTIVE_HIGH>  /* X5 */
            ;
    };
};
